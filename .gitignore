# ── Dependencies ──────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────
/.next/
/out/
/build

# ── Environment variables (NEVER commit) ──────
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Secrets / keys ────────────────────────────
*.pem
*.key
*.p8

# ── Claude Code (contains cached secrets) ─────
.claude/

# ── Vercel ────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Prisma generated client ───────────────────
prisma/generated/

# ── OS / Editor ───────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Logs ──────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Testing ───────────────────────────────────
/coverage
